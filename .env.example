# Required for YouTube collection
YOUTUBE_API_KEY=

# Optional
TWITTER_BEARER_TOKEN=
LINKEDIN_ACCESS_TOKEN=

# Optional — Google Cloud Timeseries Insights API
# Enables discussion volume anomaly detection (spikes per category)
# Get from: console.cloud.google.com -> Enable Timeseries Insights API -> Create API key
GOOGLE_CLOUD_API_KEY=
GOOGLE_CLOUD_PROJECT=
